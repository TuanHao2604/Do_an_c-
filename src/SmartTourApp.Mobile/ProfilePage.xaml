<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartTourApp.Mobile.ProfilePage"
             BackgroundColor="{StaticResource PageBackground}">
    <Grid RowDefinitions="Auto,*">

        <!-- ═══ HEADER ═══ -->
        <Grid Padding="20,14,20,24" ColumnDefinitions="*,Auto">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0E6EB8" Offset="0.0" />
                    <GradientStop Color="#1A9DE8" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>
            <Label Text="👤 Cá nhân" FontSize="18" FontFamily="UbuntuBold" TextColor="White" />
            <Frame Grid.Column="1" Padding="10,4" CornerRadius="10" HasShadow="False"
                   BackgroundColor="#33FFFFFF" BorderColor="Transparent">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped" />
                </Frame.GestureRecognizers>
                <Label Text="Đăng xuất" FontSize="11" TextColor="White" />
            </Frame>
        </Grid>

        <ScrollView Grid.Row="1" Margin="0,-16,0,0">
            <VerticalStackLayout Padding="16,0,16,28" Spacing="14">

                <!-- ═══ USER CARD ═══ -->
                <Frame CornerRadius="20" Padding="16" HasShadow="True" BorderColor="#260E6EB8">
                    <HorizontalStackLayout Spacing="14">
                        <Frame WidthRequest="60" HeightRequest="60" CornerRadius="20"
                               Padding="0" HasShadow="False" BorderColor="Transparent">
                            <Frame.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#594AE2" Offset="0.0" />
                                    <GradientStop Color="#7D70F1" Offset="1.0" />
                                </LinearGradientBrush>
                            </Frame.Background>
                            <Label Text="H" FontSize="24" FontFamily="UbuntuBold" TextColor="White"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Frame>
                        <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                            <Label Text="Hao Nguyen Tuan" FontSize="17" FontFamily="UbuntuBold" />
                            <HorizontalStackLayout Spacing="12">
                                <HorizontalStackLayout Spacing="4">
                                    <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4" Color="#22C55E" />
                                    <Label x:Name="VisitedCount" Text="0 đã thăm" FontSize="11" TextColor="#22C55E" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="4">
                                    <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4" Color="#EF4444" />
                                    <Label x:Name="FavoriteCount" Text="0 yêu thích" FontSize="11" TextColor="#EF4444" />
                                </HorizontalStackLayout>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Frame>

                <!-- ═══ STATS CARDS ═══ -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                    <Frame CornerRadius="16" Padding="12" HasShadow="False" BorderColor="{StaticResource Border}">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label x:Name="TotalPoiLabel" Text="0" FontSize="22" FontFamily="UbuntuBold"
                                   TextColor="{StaticResource Primary}" HorizontalOptions="Center" />
                            <Label Text="POI" FontSize="11" TextColor="{StaticResource InkMuted}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Frame>
                    <Frame Grid.Column="1" CornerRadius="16" Padding="12" HasShadow="False"
                           BorderColor="{StaticResource Border}">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label x:Name="TotalVisitLabel" Text="0" FontSize="22" FontFamily="UbuntuBold"
                                   TextColor="{StaticResource Accent}" HorizontalOptions="Center" />
                            <Label Text="Lượt thăm" FontSize="11" TextColor="{StaticResource InkMuted}"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Frame>
                    <Frame Grid.Column="2" CornerRadius="16" Padding="12" HasShadow="False"
                           BorderColor="{StaticResource Border}">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label x:Name="TotalNarrationLabel" Text="0s" FontSize="22" FontFamily="UbuntuBold"
                                   TextColor="#22C55E" HorizontalOptions="Center" />
                            <Label Text="Thuyết minh" FontSize="11" TextColor="{StaticResource InkMuted}"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!-- ═══ PREMIUM CARD ═══ -->
                <Frame CornerRadius="16" Padding="14" HasShadow="True" BorderColor="Transparent">
                    <Frame.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFF7E0" Offset="0.0" />
                            <GradientStop Color="#FDE68A" Offset="1.0" />
                        </LinearGradientBrush>
                    </Frame.Background>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Frame WidthRequest="40" HeightRequest="40" CornerRadius="14"
                               BackgroundColor="#F59E0B" Padding="0" HasShadow="False" BorderColor="Transparent">
                            <Label Text="👑" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Frame>
                        <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                            <Label Text="Nâng cấp Premium" FontSize="14" FontFamily="UbuntuBold"
                                   TextColor="{StaticResource Ink}" />
                            <Label Text="Hỗ trợ hướng dẫn viên địa phương, mở khóa tính năng"
                                   FontSize="11" TextColor="#A16207" />
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <!-- ═══ SETTINGS ═══ -->
                <VerticalStackLayout Spacing="4">
                    <HorizontalStackLayout Spacing="8" Padding="4,0">
                        <BoxView WidthRequest="4" HeightRequest="16" CornerRadius="2" VerticalOptions="Center"
                                 Color="{StaticResource Primary}" />
                        <Label Text="Cài đặt" FontSize="16" FontFamily="UbuntuBold" />
                    </HorizontalStackLayout>

                    <Frame CornerRadius="16" Padding="0" HasShadow="False" BorderColor="{StaticResource Border}">
                        <VerticalStackLayout Spacing="0">
                            <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,14" ColumnSpacing="12">
                                <Label Text="🌐" FontSize="16" />
                                <Label Text="Ngôn ngữ" FontSize="13" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="Tiếng Việt ›" FontSize="12"
                                       TextColor="{StaticResource InkMuted}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Border}" />
                            <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,14" ColumnSpacing="12">
                                <Label Text="🎨" FontSize="16" />
                                <Label Text="Giao diện" FontSize="13" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="Sáng ›" FontSize="12"
                                       TextColor="{StaticResource InkMuted}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Border}" />
                            <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,14" ColumnSpacing="12">
                                <Label Text="📏" FontSize="16" />
                                <Label Text="Đơn vị khoảng cách" FontSize="13" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="km ›" FontSize="12"
                                       TextColor="{StaticResource InkMuted}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Border}" />
                            <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,14" ColumnSpacing="12">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnClearHistoryTapped" />
                                </Frame.GestureRecognizers>
                                <Label Text="🗑️" FontSize="16" />
                                <Label x:Name="ClearHistoryLabel" Text="Xóa lịch sử (0)"
                                       FontSize="13" TextColor="{StaticResource InkMuted}" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="›" FontSize="16"
                                       TextColor="{StaticResource InkMuted}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>

                <!-- ═══ MORE ═══ -->
                <VerticalStackLayout Spacing="4">
                    <HorizontalStackLayout Spacing="8" Padding="4,0">
                        <BoxView WidthRequest="4" HeightRequest="16" CornerRadius="2" VerticalOptions="Center"
                                 Color="{StaticResource Primary}" />
                        <Label Text="Khác" FontSize="16" FontFamily="UbuntuBold" />
                    </HorizontalStackLayout>

                    <Frame CornerRadius="16" Padding="0" HasShadow="False" BorderColor="{StaticResource Border}">
                        <VerticalStackLayout Spacing="0">
                            <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,14" ColumnSpacing="12">
                                <Label Text="📥" FontSize="16" />
                                <Label Text="Hướng dẫn offline" FontSize="13" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="›" FontSize="16"
                                       TextColor="{StaticResource InkMuted}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Border}" />
                            <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,14" ColumnSpacing="12">
                                <Label Text="⭐" FontSize="16" />
                                <Label Text="Đánh giá ứng dụng" FontSize="13" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="›" FontSize="16"
                                       TextColor="{StaticResource InkMuted}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Border}" />
                            <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,14" ColumnSpacing="12">
                                <Label Text="💬" FontSize="16" />
                                <Label Text="Gửi góp ý" FontSize="13" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="›" FontSize="16"
                                       TextColor="{StaticResource InkMuted}" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="{StaticResource Border}" />
                            <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,14" ColumnSpacing="12">
                                <Label Text="ℹ️" FontSize="16" />
                                <Label Text="Về ứng dụng" FontSize="13" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="v1.0.0" FontSize="12"
                                       TextColor="{StaticResource InkMuted}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
