<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartTourApp.Mobile.ProfilePage"
             BackgroundColor="{StaticResource PageBackground}">
    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,28" Spacing="18">
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="Profile" FontSize="24" FontFamily="UbuntuBold" />
                <Label Grid.Column="1" Text="Log out" FontSize="12" TextColor="{StaticResource InkMuted}"
                       VerticalOptions="Center" />
            </Grid>

            <HorizontalStackLayout Spacing="14">
                <Frame WidthRequest="64" HeightRequest="64" CornerRadius="32"
                       BackgroundColor="#5B21B6" HasShadow="False">
                    <Label Text="H" FontSize="24" FontFamily="UbuntuBold" TextColor="White"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Frame>
                <VerticalStackLayout Spacing="6">
                    <Label Text="Hao Nguyen Tuan" FontSize="18" FontFamily="UbuntuMedium" />
                    <HorizontalStackLayout Spacing="10">
                        <HorizontalStackLayout Spacing="6">
                            <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4" Color="#22C55E" />
                            <Label Text="Visited places: 0" FontSize="12" TextColor="#22C55E" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="6">
                            <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4" Color="#EF4444" />
                            <Label Text="Favorite places: 0" FontSize="12" TextColor="#EF4444" />
                        </HorizontalStackLayout>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="6">
                        <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4" Color="#3B82F6" />
                        <Label Text="Tours taken: 0" FontSize="12" TextColor="#3B82F6" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <Frame CornerRadius="16" Padding="16" BackgroundColor="{StaticResource AccentSoft}"
                   BorderColor="{StaticResource Border}" HasShadow="False">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Frame WidthRequest="40" HeightRequest="40" CornerRadius="20"
                           BackgroundColor="{StaticResource Accent}" HasShadow="False">
                        <Image Source="ic_crown.svg" HeightRequest="18" WidthRequest="18"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Frame>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Subscribe to Premium" FontSize="14" FontFamily="UbuntuMedium" />
                        <Label Text="Join us in supporting local guides and get the most of your SmartGuide"
                               FontSize="11" TextColor="{StaticResource InkMuted}" />
                        <Label Text="Learn more" FontSize="11" TextColor="{StaticResource InkMuted}" />
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <Frame WidthRequest="28" HeightRequest="28" CornerRadius="14"
                       BackgroundColor="{StaticResource Surface}" BorderColor="{StaticResource Border}"
                       HasShadow="False">
                    <BoxView Color="#6B7280" CornerRadius="10" />
                </Frame>
                <Label Text="Settings" FontSize="18" FontFamily="UbuntuMedium" VerticalOptions="Center" />
            </Grid>

            <Frame CornerRadius="16" Padding="0" BackgroundColor="{StaticResource Surface}"
                   BorderColor="{StaticResource Border}" HasShadow="False">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto" Padding="16,12">
                        <Label Text="Preferred languages" FontSize="13" />
                        <Label Grid.Column="1" Text=">" FontSize="16" TextColor="{StaticResource InkMuted}" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource Border}" />
                    <Grid ColumnDefinitions="*,Auto" Padding="16,12">
                        <Label Text="Application theme" FontSize="13" />
                        <Label Grid.Column="1" Text="Light" FontSize="12" TextColor="{StaticResource InkMuted}" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource Border}" />
                    <Grid ColumnDefinitions="*,Auto" Padding="16,12">
                        <Label Text="Temperature" FontSize="13" />
                        <Label Grid.Column="1" Text="C" FontSize="12" TextColor="{StaticResource InkMuted}" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource Border}" />
                    <Grid ColumnDefinitions="*,Auto" Padding="16,12">
                        <Label Text="Distance" FontSize="13" />
                        <Label Grid.Column="1" Text="km" FontSize="12" TextColor="{StaticResource InkMuted}" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource Border}" />
                    <Grid ColumnDefinitions="*,Auto" Padding="16,12">
                        <Label Text="Clear visited history (0)" FontSize="13" TextColor="{StaticResource InkMuted}" />
                        <Label Grid.Column="1" Text=">" FontSize="16" TextColor="{StaticResource InkMuted}" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Frame CornerRadius="16" Padding="0" BackgroundColor="{StaticResource Surface}"
                   BorderColor="{StaticResource Border}" HasShadow="False">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,12" ColumnSpacing="12">
                        <Image Source="ic_crown.svg" HeightRequest="18" WidthRequest="18" />
                        <Label Text="Offline guides" FontSize="13" VerticalOptions="Center" />
                        <Label Grid.Column="2" Text=">" FontSize="16" TextColor="{StaticResource InkMuted}" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource Border}" />
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,12" ColumnSpacing="12">
                        <Image Source="ic_explore.svg" HeightRequest="18" WidthRequest="18" />
                        <Label Text="Send me travel tips" FontSize="13" VerticalOptions="Center" />
                        <Switch Grid.Column="2" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource Border}" />
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,12" ColumnSpacing="12">
                        <Image Source="ic_map.svg" HeightRequest="18" WidthRequest="18" />
                        <Label Text="Restore purchases" FontSize="13" VerticalOptions="Center" />
                        <Label Grid.Column="2" Text=">" FontSize="16" TextColor="{StaticResource InkMuted}" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource Border}" />
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,12" ColumnSpacing="12">
                        <Image Source="ic_heart.svg" HeightRequest="18" WidthRequest="18" />
                        <Label Text="Rate the App" FontSize="13" VerticalOptions="Center" />
                        <Label Grid.Column="2" Text=">" FontSize="16" TextColor="{StaticResource InkMuted}" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource Border}" />
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,12" ColumnSpacing="12">
                        <Image Source="ic_profile.svg" HeightRequest="18" WidthRequest="18" />
                        <Label Text="Share feedback" FontSize="13" VerticalOptions="Center" />
                        <Label Grid.Column="2" Text=">" FontSize="16" TextColor="{StaticResource InkMuted}" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource Border}" />
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,12" ColumnSpacing="12">
                        <Image Source="ic_search.svg" HeightRequest="18" WidthRequest="18" />
                        <Label Text="About application" FontSize="13" VerticalOptions="Center" />
                        <Label Grid.Column="2" Text=">" FontSize="16" TextColor="{StaticResource InkMuted}" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource Border}" />
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,12" ColumnSpacing="12">
                        <Image Source="ic_target.svg" HeightRequest="18" WidthRequest="18" />
                        <Label Text="Delete account" FontSize="13" VerticalOptions="Center" />
                        <Label Grid.Column="2" Text=">" FontSize="16" TextColor="{StaticResource InkMuted}" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
