<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
             x:Class="SmartTourApp.Mobile.MapPage"
             BackgroundColor="{StaticResource PageBackground}">
    <Grid RowDefinitions="Auto,*">
        <Grid Padding="20,16,20,10" ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <Frame CornerRadius="24" Padding="14,12"
                   BackgroundColor="{StaticResource Surface}"
                   BorderColor="{StaticResource Border}" HasShadow="True">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSearchTapped" />
                </Frame.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" VerticalOptions="Center">
                    <Image Source="ic_search.svg" HeightRequest="18" WidthRequest="18" />
                    <Label Text="Find destinations worldwide"
                           FontSize="14" TextColor="{StaticResource InkMuted}"
                           VerticalOptions="Center" />
                </Grid>
            </Frame>
            <Frame WidthRequest="48" HeightRequest="48" CornerRadius="24"
                   Padding="10" BackgroundColor="{StaticResource Accent}"
                   HasShadow="True" HorizontalOptions="End">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPremiumTapped" />
                </Frame.GestureRecognizers>
                <Image Source="ic_crown.svg" HeightRequest="22" WidthRequest="22" />
            </Frame>
        </Grid>

        <Grid Grid.Row="1" Padding="20,10,20,20" RowDefinitions="*,Auto" RowSpacing="12">
            <Grid Grid.Row="0">
                <maps:Map x:Name="PoiMap" MapType="Street" IsShowingUser="True" />

                <VerticalStackLayout Spacing="12" HorizontalOptions="End" VerticalOptions="End" Margin="0,0,16,16">
                    <Frame WidthRequest="48" HeightRequest="48" CornerRadius="24"
                           BackgroundColor="{StaticResource Surface}" BorderColor="{StaticResource Border}"
                           HasShadow="True">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLayersTapped" />
                        </Frame.GestureRecognizers>
                        <Image Source="ic_layers.svg" HeightRequest="20" WidthRequest="20" />
                    </Frame>
                    <Frame WidthRequest="48" HeightRequest="48" CornerRadius="24"
                           BackgroundColor="{StaticResource Surface}" BorderColor="{StaticResource Border}"
                           HasShadow="True">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTargetTapped" />
                        </Frame.GestureRecognizers>
                        <Image Source="ic_target.svg" HeightRequest="20" WidthRequest="20" />
                    </Frame>
                </VerticalStackLayout>
            </Grid>

            <Frame Grid.Row="1" CornerRadius="16" Padding="12"
                   BackgroundColor="{StaticResource Surface}" BorderColor="{StaticResource Border}"
                   HasShadow="False">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Heatmap (top 12)" FontSize="12" FontFamily="UbuntuMedium" />
                    <VerticalStackLayout x:Name="MapHeatmapList" Spacing="6">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="{Binding CellKey}" FontSize="12" />
                                    <Label Grid.Column="1" Text="{Binding Count}" FontSize="12"
                                           TextColor="{StaticResource InkMuted}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                    <Label x:Name="MapHeatmapEmpty" Text="Chua co du lieu heatmap."
                           FontSize="12" TextColor="{StaticResource InkMuted}" IsVisible="False" />
                    <Label x:Name="MapLastLocationLabel" Text="Vi tri gan nhat: --"
                           FontSize="11" TextColor="{StaticResource InkMuted}" />
                </VerticalStackLayout>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
