<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartTourApp.Mobile.ExplorePage"
             BackgroundColor="{StaticResource PageBackground}">
    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,28" Spacing="20">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <Frame CornerRadius="24" Padding="14,12"
                       BackgroundColor="{StaticResource Surface}"
                       BorderColor="{StaticResource Border}" HasShadow="True">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSearchTapped" />
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" VerticalOptions="Center">
                        <Image Source="ic_search.svg" HeightRequest="18" WidthRequest="18" />
                        <Label Text="Find destinations worldwide"
                               FontSize="14" TextColor="{StaticResource InkMuted}"
                               VerticalOptions="Center" />
                    </Grid>
                </Frame>
                <Frame WidthRequest="48" HeightRequest="48" CornerRadius="24"
                       Padding="10" BackgroundColor="{StaticResource Accent}"
                       HasShadow="True" HorizontalOptions="End">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPremiumTapped" />
                    </Frame.GestureRecognizers>
                    <Image Source="ic_crown.svg" HeightRequest="22" WidthRequest="22" />
                </Frame>
            </Grid>

            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10" VerticalOptions="Center">
                <Frame CornerRadius="16" Padding="10,6"
                       BackgroundColor="{StaticResource Surface}"
                       BorderColor="{StaticResource Border}" HasShadow="False">
                    <Label x:Name="SyncStatusLabel" Text="Chua dong bo"
                           FontSize="11" TextColor="{StaticResource InkMuted}" />
                </Frame>
                <Button Text="Dong bo" FontSize="12" Clicked="OnSyncClicked"
                        BackgroundColor="{StaticResource Ink}" />
                <Button Text="Gan toi" FontSize="12" Clicked="OnNearbyClicked"
                        BackgroundColor="{StaticResource Accent}"
                        TextColor="{StaticResource Ink}" />
                <Button Text="Quet QR" FontSize="12" Clicked="OnQrClicked"
                        BackgroundColor="{StaticResource Surface}"
                        TextColor="{StaticResource Ink}" />
            </Grid>

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" VerticalOptions="Center">
                <Label Text="Luu tuyen di (an danh)" FontSize="12" TextColor="{StaticResource InkMuted}" />
                <Switch x:Name="TrackingSwitch" Toggled="OnTrackingToggled" />
            </Grid>
            <Label x:Name="RouteSessionLabel" Text="Chua bat theo doi" FontSize="11" TextColor="{StaticResource InkMuted}" />

            <Frame CornerRadius="20" Padding="0" BackgroundColor="{StaticResource MapSurface}"
                   BorderColor="{StaticResource Border}" HasShadow="False">
                <AbsoluteLayout HeightRequest="170">
                    <BoxView Color="{StaticResource MapSurface}"
                             AbsoluteLayout.LayoutBounds="0,0,1,1"
                             AbsoluteLayout.LayoutFlags="All" />
                    <BoxView Color="{StaticResource MapLand}" CornerRadius="24" Opacity="0.85"
                             AbsoluteLayout.LayoutBounds="0.1,0.15,0.8,0.7"
                             AbsoluteLayout.LayoutFlags="All" />

                    <Frame Padding="12,6" CornerRadius="16" HasShadow="True"
                           BackgroundColor="{StaticResource Surface}" BorderColor="{StaticResource Border}"
                           AbsoluteLayout.LayoutBounds="0.2,0.35,-1,-1"
                           AbsoluteLayout.LayoutFlags="PositionProportional">
                        <Label Text="North America" FontSize="12" FontFamily="UbuntuMedium" />
                    </Frame>
                    <Frame Padding="12,6" CornerRadius="16" HasShadow="True"
                           BackgroundColor="{StaticResource Surface}" BorderColor="{StaticResource Border}"
                           AbsoluteLayout.LayoutBounds="0.22,0.7,-1,-1"
                           AbsoluteLayout.LayoutFlags="PositionProportional">
                        <Label Text="South America" FontSize="12" FontFamily="UbuntuMedium" />
                    </Frame>
                    <Frame Padding="12,6" CornerRadius="16" HasShadow="True"
                           BackgroundColor="{StaticResource Surface}" BorderColor="{StaticResource Border}"
                           AbsoluteLayout.LayoutBounds="0.55,0.35,-1,-1"
                           AbsoluteLayout.LayoutFlags="PositionProportional">
                        <Label Text="Europe" FontSize="12" FontFamily="UbuntuMedium" />
                    </Frame>
                    <Frame Padding="12,6" CornerRadius="16" HasShadow="True"
                           BackgroundColor="{StaticResource Surface}" BorderColor="{StaticResource Border}"
                           AbsoluteLayout.LayoutBounds="0.55,0.6,-1,-1"
                           AbsoluteLayout.LayoutFlags="PositionProportional">
                        <Label Text="Africa" FontSize="12" FontFamily="UbuntuMedium" />
                    </Frame>
                    <Frame Padding="12,6" CornerRadius="16" HasShadow="True"
                           BackgroundColor="{StaticResource Surface}" BorderColor="{StaticResource Border}"
                           AbsoluteLayout.LayoutBounds="0.78,0.38,-1,-1"
                           AbsoluteLayout.LayoutFlags="PositionProportional">
                        <Label Text="Asia" FontSize="12" FontFamily="UbuntuMedium" />
                    </Frame>
                    <Frame Padding="12,6" CornerRadius="16" HasShadow="True"
                           BackgroundColor="{StaticResource Surface}" BorderColor="{StaticResource Border}"
                           AbsoluteLayout.LayoutBounds="0.82,0.72,-1,-1"
                           AbsoluteLayout.LayoutFlags="PositionProportional">
                        <Label Text="Oceania" FontSize="12" FontFamily="UbuntuMedium" />
                    </Frame>
                </AbsoluteLayout>
            </Frame>

            <Frame x:Name="NearestPoiCard" CornerRadius="16" Padding="14"
                   BackgroundColor="{StaticResource Surface}"
                   BorderColor="{StaticResource Border}" HasShadow="True"
                   IsVisible="False">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="POI gan nhat" FontSize="12" TextColor="{StaticResource InkMuted}" />
                        <Label x:Name="NearestPoiName" FontSize="16" FontFamily="UbuntuMedium" />
                        <Label x:Name="NearestPoiDistance" FontSize="12" TextColor="{StaticResource InkMuted}" />
                    </VerticalStackLayout>
                    <Button Text="Nghe" FontSize="12" Clicked="OnNearestNarrateClicked"
                            BackgroundColor="{StaticResource Ink}" />
                </Grid>
            </Frame>

            <Label Text="Recently opened" FontSize="22" FontFamily="UbuntuBold" />

            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                <Frame WidthRequest="54" HeightRequest="54" CornerRadius="14"
                       Padding="0" BackgroundColor="{StaticResource SurfaceAlt}"
                       BorderColor="{StaticResource Border}" HasShadow="False">
                    <Grid Background="{StaticResource ImageGradient}" />
                </Frame>
                <VerticalStackLayout Spacing="2">
                    <Label Text="Ho Chi Minh" FontSize="16" FontFamily="UbuntuMedium" />
                    <Label Text="City" FontSize="12" TextColor="{StaticResource InkMuted}" />
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <Frame CornerRadius="18" Padding="0" HasShadow="True"
                   BackgroundColor="{StaticResource Surface}">
                <Grid HeightRequest="210">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#8EC5FC" Offset="0.0" />
                            <GradientStop Color="#E0C3FC" Offset="1.0" />
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Frame Padding="10,6" CornerRadius="12" HasShadow="False"
                           BackgroundColor="{StaticResource Success}"
                           HorizontalOptions="Start" VerticalOptions="Start"
                           Margin="12">
                        <Label Text="At the destination" FontSize="11" TextColor="White" />
                    </Frame>
                    <BoxView Color="Black" Opacity="0.35" HeightRequest="70"
                             VerticalOptions="End" />
                    <VerticalStackLayout Spacing="4" Padding="16,0,16,14"
                                         VerticalOptions="End">
                        <Label Text="Ho Chi Minh City" FontSize="24" FontFamily="UbuntuBold"
                               TextColor="White" />
                        <Label Text="Explore nearby places" FontSize="12" TextColor="White" />
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <Frame CornerRadius="14" Padding="12" HasShadow="False"
                   BackgroundColor="{StaticResource Surface}" BorderColor="{StaticResource Border}">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" VerticalOptions="Center">
                    <Frame WidthRequest="40" HeightRequest="40" CornerRadius="20"
                           BackgroundColor="#E11D48" HasShadow="False">
                        <BoxView Color="#2563EB" CornerRadius="20" />
                    </Frame>
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Cambodia" FontSize="14" FontFamily="UbuntuMedium" />
                        <Label Text="Explore 1 destination" FontSize="12" TextColor="{StaticResource InkMuted}" />
                    </VerticalStackLayout>
                    <Label Text=">" FontSize="18" TextColor="{StaticResource InkMuted}"
                           VerticalOptions="Center" />
                </Grid>
            </Frame>

            <Label Text="Nearby destinations" FontSize="22" FontFamily="UbuntuBold" />

            <VerticalStackLayout x:Name="PoiEmptyView" Spacing="6" IsVisible="False">
                <Label Text="Khong co du lieu" FontSize="14" FontFamily="UbuntuMedium" />
                <Label Text="Nhan Dong bo de tai danh sach diem den."
                       FontSize="12" TextColor="{StaticResource InkMuted}" />
            </VerticalStackLayout>

            <VerticalStackLayout x:Name="PoiListLayout" Spacing="12">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Frame CornerRadius="16" Padding="12"
                               BackgroundColor="{StaticResource Surface}"
                               BorderColor="{StaticResource Border}" HasShadow="True">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPoiTapped" CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                <Label Text="{Binding Name}" FontSize="16" FontFamily="UbuntuMedium" />
                                <Frame Grid.Column="1" Padding="8,4" CornerRadius="10"
                                       BackgroundColor="{StaticResource SurfaceAlt}"
                                       BorderColor="{StaticResource Border}" HasShadow="False">
                                    <Label Text="{Binding CategoryName}" FontSize="11"
                                           TextColor="{StaticResource InkMuted}" />
                                </Frame>
                                <Label Grid.Row="1" Grid.ColumnSpan="2"
                                       Text="{Binding Address}" FontSize="12"
                                       TextColor="{StaticResource InkMuted}" Margin="0,6,0,0" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Frame CornerRadius="18" Padding="0" HasShadow="True"
                   BackgroundColor="{StaticResource Surface}">
                <Grid HeightRequest="180">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#F97316" Offset="0.0" />
                            <GradientStop Color="#FACC15" Offset="1.0" />
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Image Source="ic_heart.svg" HeightRequest="20" WidthRequest="20"
                           HorizontalOptions="End" VerticalOptions="Start" Margin="12" />
                    <Frame Padding="10,6" CornerRadius="12" HasShadow="False"
                           BackgroundColor="#111827" HorizontalOptions="End"
                           VerticalOptions="End" Margin="12">
                        <Label Text="425 km" FontSize="11" TextColor="White" />
                    </Frame>
                </Grid>
            </Frame>
            <Label Text="Angkor Wat" FontSize="16" FontFamily="UbuntuMedium" />
            <Label Text="Cambodia" FontSize="12" TextColor="{StaticResource InkMuted}" />

            <Label Text="Thong ke nhanh" FontSize="20" FontFamily="UbuntuBold" />
            <Frame CornerRadius="16" Padding="14" BackgroundColor="{StaticResource Surface}"
                   BorderColor="{StaticResource Border}" HasShadow="False">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Top dia diem di nhieu nhat" FontSize="13" FontFamily="UbuntuMedium" />
                    <VerticalStackLayout x:Name="TopVisitedList" Spacing="6">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="{Binding PoiName}" FontSize="12" />
                                    <Label Grid.Column="1" Text="{Binding VisitCount}" FontSize="12"
                                           TextColor="{StaticResource InkMuted}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                    <Label x:Name="AverageNarrationLabel" Text="Thời gian thuyết minh trung bình: --"
                           FontSize="12" TextColor="{StaticResource InkMuted}" />
                </VerticalStackLayout>
            </Frame>

            <Label Text="Heatmap vi tri nguoi dung" FontSize="20" FontFamily="UbuntuBold" />
            <Frame CornerRadius="16" Padding="14" BackgroundColor="{StaticResource Surface}"
                   BorderColor="{StaticResource Border}" HasShadow="False">
                <VerticalStackLayout Spacing="8">
                    <VerticalStackLayout x:Name="HeatmapList" Spacing="6">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="{Binding CellKey}" FontSize="12" />
                                    <Label Grid.Column="1" Text="{Binding Count}" FontSize="12"
                                           TextColor="{StaticResource InkMuted}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                    <Label x:Name="HeatmapEmptyLabel" Text="Chua co du lieu heatmap."
                           FontSize="12" TextColor="{StaticResource InkMuted}" IsVisible="False" />
                </VerticalStackLayout>
            </Frame>

            <Label Text="Nearby countries" FontSize="22" FontFamily="UbuntuBold" />

            <ScrollView Orientation="Horizontal">
                <HorizontalStackLayout Spacing="14">
                    <Frame WidthRequest="160" CornerRadius="16" Padding="0" HasShadow="True">
                        <Grid HeightRequest="120">
                            <Grid.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#60A5FA" Offset="0.0" />
                                    <GradientStop Color="#A7F3D0" Offset="1.0" />
                                </LinearGradientBrush>
                            </Grid.Background>
                            <Frame WidthRequest="32" HeightRequest="32" CornerRadius="16"
                                   BackgroundColor="White" HasShadow="False"
                                   HorizontalOptions="Start" VerticalOptions="End" Margin="10">
                                <BoxView Color="#DC2626" CornerRadius="16" />
                            </Frame>
                            <Image Source="ic_heart.svg" HeightRequest="16" WidthRequest="16"
                                   HorizontalOptions="End" VerticalOptions="Start" Margin="10" />
                        </Grid>
                        <Label Text="Singapore" FontSize="13" FontFamily="UbuntuMedium" Margin="10,8,10,12" />
                    </Frame>

                    <Frame WidthRequest="160" CornerRadius="16" Padding="0" HasShadow="True">
                        <Grid HeightRequest="120">
                            <Grid.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FDE68A" Offset="0.0" />
                                    <GradientStop Color="#FDBA74" Offset="1.0" />
                                </LinearGradientBrush>
                            </Grid.Background>
                            <Frame WidthRequest="32" HeightRequest="32" CornerRadius="16"
                                   BackgroundColor="White" HasShadow="False"
                                   HorizontalOptions="Start" VerticalOptions="End" Margin="10">
                                <BoxView Color="#16A34A" CornerRadius="16" />
                            </Frame>
                            <Image Source="ic_heart.svg" HeightRequest="16" WidthRequest="16"
                                   HorizontalOptions="End" VerticalOptions="Start" Margin="10" />
                        </Grid>
                        <Label Text="Myanmar" FontSize="13" FontFamily="UbuntuMedium" Margin="10,8,10,12" />
                    </Frame>

                    <Frame WidthRequest="160" CornerRadius="16" Padding="0" HasShadow="True">
                        <Grid HeightRequest="120">
                            <Grid.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#A78BFA" Offset="0.0" />
                                    <GradientStop Color="#60A5FA" Offset="1.0" />
                                </LinearGradientBrush>
                            </Grid.Background>
                            <Frame WidthRequest="32" HeightRequest="32" CornerRadius="16"
                                   BackgroundColor="White" HasShadow="False"
                                   HorizontalOptions="Start" VerticalOptions="End" Margin="10">
                                <BoxView Color="#2563EB" CornerRadius="16" />
                            </Frame>
                            <Image Source="ic_heart.svg" HeightRequest="16" WidthRequest="16"
                                   HorizontalOptions="End" VerticalOptions="Start" Margin="10" />
                        </Grid>
                        <Label Text="Philippines" FontSize="13" FontFamily="UbuntuMedium" Margin="10,8,10,12" />
                    </Frame>
                </HorizontalStackLayout>
            </ScrollView>

            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                <Label Text="Experiences" FontSize="22" FontFamily="UbuntuBold" />
                <Label Grid.Column="1" Text="See all" FontSize="12" TextColor="{StaticResource InkMuted}"
                       VerticalOptions="Center" />
            </Grid>

            <ScrollView Orientation="Horizontal">
                <HorizontalStackLayout Spacing="14">
                    <Frame WidthRequest="180" CornerRadius="16" Padding="0" HasShadow="True">
                        <Grid HeightRequest="130" Background="{StaticResource ImageGradient}" />
                        <VerticalStackLayout Padding="10,8,10,12" Spacing="4">
                            <Label Text="Saigon City" FontSize="13" FontFamily="UbuntuMedium" />
                            <Label Text="Sightseeing Hop-On" FontSize="11" TextColor="{StaticResource InkMuted}" />
                            <Label Text="From 575300 VND" FontSize="10" TextColor="{StaticResource InkMuted}" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame WidthRequest="180" CornerRadius="16" Padding="0" HasShadow="True">
                        <Grid HeightRequest="130">
                            <Grid.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FDE68A" Offset="0.0" />
                                    <GradientStop Color="#93C5FD" Offset="1.0" />
                                </LinearGradientBrush>
                            </Grid.Background>
                        </Grid>
                        <VerticalStackLayout Padding="10,8,10,12" Spacing="4">
                            <Label Text="Bitexco Tower" FontSize="13" FontFamily="UbuntuMedium" />
                            <Label Text="Saigon Sky" FontSize="11" TextColor="{StaticResource InkMuted}" />
                            <Label Text="From 273900 VND" FontSize="10" TextColor="{StaticResource InkMuted}" />
                        </VerticalStackLayout>
                    </Frame>
                </HorizontalStackLayout>
            </ScrollView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
