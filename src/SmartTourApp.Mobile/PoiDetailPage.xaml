<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartTourApp.Mobile.PoiDetailPage"
             BackgroundColor="{StaticResource PageBackground}"
             NavigationPage.HasNavigationBar="False">
    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ═══ HERO SECTION ═══ -->
        <Grid HeightRequest="280">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0E6EB8" Offset="0.0" />
                    <GradientStop Color="#1A9DE8" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>
            <!-- Gradient overlay -->
            <BoxView VerticalOptions="End" HeightRequest="140">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="Transparent" Offset="0.0" />
                        <GradientStop Color="#CC000000" Offset="1.0" />
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>
            <!-- Back button -->
            <Frame WidthRequest="40" HeightRequest="40" CornerRadius="14"
                   BackgroundColor="#55FFFFFF" Padding="0" HasShadow="False" BorderColor="Transparent"
                   HorizontalOptions="Start" VerticalOptions="Start" Margin="16,48,0,0">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Frame.GestureRecognizers>
                <Label Text="←" FontSize="20" TextColor="White"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Frame>
            <!-- Title on hero -->
            <VerticalStackLayout VerticalOptions="End" Padding="20,20" Spacing="6">
                <Label x:Name="HeroTitle" Text="" FontSize="24" FontFamily="UbuntuBold"
                       TextColor="White" />
                <HorizontalStackLayout Spacing="8">
                    <Frame Padding="6,3" CornerRadius="8" HasShadow="False"
                           BackgroundColor="#33FFFFFF" BorderColor="Transparent">
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="⭐" FontSize="11" />
                            <Label Text="4.8" FontSize="11" FontFamily="UbuntuBold" TextColor="White" />
                        </HorizontalStackLayout>
                    </Frame>
                    <Frame Padding="8,3" CornerRadius="8" HasShadow="False"
                           BackgroundColor="#333B82F6" BorderColor="Transparent">
                        <Label x:Name="HeroCategory" Text="" FontSize="11" TextColor="White" />
                    </Frame>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Grid>

        <!-- ═══ CONTENT (overlaps hero) ═══ -->
        <ScrollView Grid.Row="1" Margin="0,-32,0,0">
            <Frame CornerRadius="28" Padding="0" HasShadow="True"
                   BackgroundColor="{StaticResource Surface}" BorderColor="Transparent">
                <VerticalStackLayout Padding="20,24,20,20" Spacing="20">

                    <!-- ═══ QUICK ACTIONS ═══ -->
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDirectionTapped" />
                            </Frame.GestureRecognizers>
                            <Frame WidthRequest="50" HeightRequest="50" CornerRadius="25"
                                   Padding="0" HasShadow="True" BorderColor="Transparent">
                                <Frame.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#594AE2" Offset="0.0" />
                                        <GradientStop Color="#7D70F1" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Frame.Background>
                                <Label Text="🧭" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Frame>
                            <Label Text="Chỉ đường" FontSize="11" TextColor="{StaticResource InkMuted}"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="6" HorizontalOptions="Center">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnNarrateTapped" />
                            </Frame.GestureRecognizers>
                            <Frame WidthRequest="50" HeightRequest="50" CornerRadius="25"
                                   Padding="0" HasShadow="True" BorderColor="Transparent">
                                <Frame.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF4081" Offset="0.0" />
                                        <GradientStop Color="#FF80AB" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Frame.Background>
                                <Label Text="🎧" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Frame>
                            <Label Text="Thuyết minh" FontSize="11" TextColor="{StaticResource InkMuted}"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="2" Spacing="6" HorizontalOptions="Center">
                            <Frame WidthRequest="50" HeightRequest="50" CornerRadius="25"
                                   Padding="0" HasShadow="True" BorderColor="Transparent">
                                <Frame.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#4CAF50" Offset="0.0" />
                                        <GradientStop Color="#81C784" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Frame.Background>
                                <Label Text="🔗" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Frame>
                            <Label Text="Chia sẻ" FontSize="11" TextColor="{StaticResource InkMuted}"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="3" Spacing="6" HorizontalOptions="Center">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFavoriteTapped" />
                            </Frame.GestureRecognizers>
                            <Frame WidthRequest="50" HeightRequest="50" CornerRadius="25"
                                   Padding="0" HasShadow="True" BorderColor="Transparent">
                                <Frame.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#2196F3" Offset="0.0" />
                                        <GradientStop Color="#64B5F6" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Frame.Background>
                                <Label Text="❤" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Frame>
                            <Label Text="Yêu thích" FontSize="11" TextColor="{StaticResource InkMuted}"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Grid>

                    <!-- ═══ DESCRIPTION ═══ -->
                    <VerticalStackLayout Spacing="10">
                        <HorizontalStackLayout Spacing="8">
                            <BoxView WidthRequest="4" HeightRequest="20" CornerRadius="2"
                                     Color="{StaticResource Primary}" />
                            <Label Text="Giới thiệu" FontSize="17" FontFamily="UbuntuBold" />
                        </HorizontalStackLayout>
                        <Label x:Name="DescriptionLabel" Text=""
                               FontSize="14" TextColor="#555555" LineHeight="1.6" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{StaticResource Border}" Opacity="0.5" />

                    <!-- ═══ INFO ═══ -->
                    <VerticalStackLayout Spacing="10">
                        <HorizontalStackLayout Spacing="8">
                            <BoxView WidthRequest="4" HeightRequest="20" CornerRadius="2"
                                     Color="{StaticResource Primary}" />
                            <Label Text="Thông tin" FontSize="17" FontFamily="UbuntuBold" />
                        </HorizontalStackLayout>

                        <Frame CornerRadius="14" Padding="12" HasShadow="False"
                               BackgroundColor="{StaticResource SurfaceAlt}" BorderColor="{StaticResource Border}">
                            <VerticalStackLayout Spacing="8">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <Label Text="📍" FontSize="14" />
                                    <Label x:Name="CoordinatesLabel" Text="" FontSize="12"
                                           TextColor="{StaticResource InkMuted}" VerticalOptions="Center" />
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <Label Text="📂" FontSize="14" />
                                    <Label x:Name="CategoryLabel" Text="" FontSize="12"
                                           TextColor="{StaticResource InkMuted}" VerticalOptions="Center" />
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <Label Text="📐" FontSize="14" />
                                    <Label x:Name="GeofenceLabel" Text="" FontSize="12"
                                           TextColor="{StaticResource InkMuted}" VerticalOptions="Center" />
                                </Grid>
                            </VerticalStackLayout>
                        </Frame>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="{StaticResource Border}" Opacity="0.5" />

                    <!-- ═══ LOCATION CARD ═══ -->
                    <Frame CornerRadius="16" Padding="14" HasShadow="False"
                           BackgroundColor="{StaticResource SurfaceAlt}" BorderColor="{StaticResource Border}">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDirectionTapped" />
                        </Frame.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Frame WidthRequest="44" HeightRequest="44" CornerRadius="12"
                                   Padding="0" HasShadow="True"
                                   BackgroundColor="{StaticResource Surface}" BorderColor="Transparent">
                                <Label Text="📍" FontSize="18"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Frame>
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                <Label Text="Xem trên bản đồ" FontSize="14" FontFamily="UbuntuBold" />
                                <Label x:Name="LocationSubtitle" Text="" FontSize="11"
                                       TextColor="{StaticResource InkMuted}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="24"
                                   TextColor="{StaticResource InkMuted}" VerticalOptions="Center" />
                        </Grid>
                    </Frame>

                    <!-- spacer -->
                    <BoxView HeightRequest="80" Color="Transparent" />
                </VerticalStackLayout>
            </Frame>
        </ScrollView>

        <!-- ═══ STICKY CTA ═══ -->
        <Frame Grid.Row="2" Padding="16,10" CornerRadius="0" HasShadow="True"
               BackgroundColor="{StaticResource Surface}" BorderColor="Transparent">
            <Button Text="🗺️ BẮT ĐẦU HÀNH TRÌNH" FontSize="15" FontFamily="UbuntuBold"
                    CornerRadius="28" HeightRequest="52"
                    Clicked="OnStartJourneyClicked">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0E6EB8" Offset="0.0" />
                        <GradientStop Color="#1A9DE8" Offset="1.0" />
                    </LinearGradientBrush>
                </Button.Background>
            </Button>
        </Frame>
    </Grid>
</ContentPage>
