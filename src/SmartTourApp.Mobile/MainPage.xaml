<?xml version="1.0" encoding="utf-8" ?>
<TabbedPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            xmlns:local="clr-namespace:SmartTourApp.Mobile"
            x:Class="SmartTourApp.Mobile.MainPage"
            BackgroundColor="{StaticResource PageBackground}"
            BarBackgroundColor="{StaticResource Surface}"
            BarTextColor="{StaticResource InkMuted}"
            SelectedTabColor="{StaticResource Primary}"
            UnselectedTabColor="{StaticResource InkMuted}">

    <local:ExplorePage Title="Khám phá" IconImageSource="ic_explore.svg" />
    <local:MapPage Title="Bản đồ" IconImageSource="ic_map.svg" />
    <local:FavoritesPage Title="Yêu thích" IconImageSource="ic_heart.svg" />
    <local:ProfilePage Title="Cá nhân" IconImageSource="ic_profile.svg" />
</TabbedPage>
